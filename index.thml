const STYLES=[
{color:"#5b2c8d",
es:{name:"Presionador Frontal",desc:"Avanza constantemente — esquinas — quita la distancia",problem:"Si retrocedes en línea recta te acorrala",tell:"Hombros hundiéndose — rodillas flexionando antes de avanzar",planA:"Jab control + retroceso lateral + pivote 45° + contragolpe cuando pasa + salida",planB:"Cerrar distancia + ráfaga corta 4-6 golpes adentro + salida lateral",pts:["Jab constante — yo controlo la distancia — no lo dejo cerrar","Cuando avanza — retroceso lateral + pivote — NUNCA en línea recta","Después del pivote — contragolpe + salida — no quedarme a forcejear"],r1:"Usar jab para medir — ver cómo avanza — identificar la señal",r2:"Plan A confirmado — ejecutar con confianza — retroceso lateral automático",r3:"Si cansado — contrapresión — si no — mantener Plan A"},
en:{name:"Frontal Pressure Fighter",desc:"Constantly advances — corners you — takes away distance",problem:"If you retreat in a straight line they corner you",tell:"Shoulders hunching — knees bending before advancing",planA:"Jab control + lateral retreat + 45° pivot + counter when they pass + exit",planB:"Close distance + short 4-6 punch burst inside + lateral exit",pts:["Constant jab — I control the distance — don't let them close","When they advance — lateral retreat + pivot — NEVER straight back","After the pivot — counter + exit — don't stay to grapple"],r1:"Use jab to measure — see how they advance — identify the tell",r2:"Plan A confirmed — execute with confidence — automatic lateral retreat",r3:"If tired — counter-pressure — if not — maintain Plan A"}},
{color:"#8b1a1a",
es:{name:"Buscador del Cuerpo",desc:"Entra agachado — golpea al hígado y plexo — exige cintura y protección baja",problem:"Los golpes al cuerpo se acumulan — si llegan muchos el cuerpo se cierra",tell:"Ojos bajando hacia el cuerpo — rodillas flexionan más de lo normal",planA:"Jab desde arriba para interrumpir + rotación de cadera en impacto + gancho arriba (la cabeza baja está en rango) + salida lateral",planB:"Cerrar distancia + clinch defensivo + salida — no dejarlo plantarse",pts:["Cuando la cabeza baja — gancho desde arriba — la cabeza está en rango","Rotación activa de cadera — no absorber recto — cintura en el impacto","Salida lateral siempre — no quedarme donde quiere trabajar"],r1:"Identificar señal cuando va al cuerpo — preparar gancho arriba",r2:"Gancho desde arriba cuando baja la cabeza — si funciona — repetir siempre",r3:"Si lastimamos arriba — va menos al cuerpo — más espacio para dominar"},
en:{name:"Body Puncher",desc:"Comes in crouching — targets body — demands waist and low protection",problem:"Body shots accumulate — if too many land the body shuts down",tell:"Eyes drop toward body — knees bend more than normal",planA:"Jab from above to interrupt + hip rotation on impact + upstairs hook (lowered head is in range) + lateral exit",planB:"Close distance + defensive clinch + exit — don't let them get set",pts:["When head drops — hook from above — the head is in range","Active hip rotation — don't absorb straight — waist on impact","Lateral exit always — don't stay where they want to work"],r1:"Identify tell when going to body — prepare upstairs hook",r2:"Hook from above when head drops — if working — repeat every time",r3:"If we hurt upstairs — they go to body less — more space to dominate"}},
{color:"#1a4a7a",
es:{name:"Contragolpeador",desc:"Espera el ataque para responder — paciente — pega en la entrada",problem:"Si atacas en línea recta tiene tu contragolpe esperando",tell:"Peso en pie de atrás — guardia alta cerrada — ojos fijos esperando",planA:"Falsa entrada + esperar la reacción + entrar con combinación DESPUÉS de que lance el contragolpe",planB:"Jab constante para romper concentración + cambio de ritmo + entrada rápida cuando menos espera",pts:["Falsa entrada primero — ver cómo reacciona — leer el plan","Entrar DESPUÉS de que lance — nunca al mismo tiempo","Cambiar el ritmo — rápido y lento — no puede esperar si no sabe cuándo"],r1:"Testear con falsas entradas — ver su respuesta preferida",r2:"Usar su respuesta preferida para predecirla y contrarrestarla",r3:"Más presión — si cansado — el contragolpeador pierde velocidad de reacción"},
en:{name:"Counter-Puncher",desc:"Waits for your attack to respond — patient — lands on entry",problem:"If you attack in a straight line they have your counter ready",tell:"Weight on back foot — high closed guard — eyes fixed waiting",planA:"False attack + wait for reaction + enter with combination AFTER they throw the counter",planB:"Constant jab to break concentration + rhythm change + quick entry when least expected",pts:["False attack first — see how they react — read the plan","Enter AFTER they throw — never at the same time","Change the rhythm — fast and slow — they can't wait if they don't know when"],r1:"Test with false attacks — see their preferred response",r2:"Use their preferred response to predict and counter it",r3:"More pressure — if tired — counter-puncher loses reaction speed"}},
{color:"#2c5f7a",
es:{name:"Rival Zurdo",desc:"El cruzado zurdo llega desde un ángulo inesperado — desorienta a quienes no lo conocen",problem:"El cruzado zurdo llega exactamente donde no esperas — desde el lado derecho",tell:"Hombro derecho sube ligeramente antes de tirar el cruzado",planA:"Jab + paso a la DERECHA del rival + el cruzado pasa por afuera + combinación desde el ángulo + salida",planB:"Cerrar distancia + trabajo adentro — el cruzado zurdo pierde potencia en distancia corta",pts:["Paso a la derecha SIEMPRE — el cruzado zurdo pasa por afuera","Combinación desde el ángulo derecho — no puede responder bien desde ahí","NUNCA en línea recta — el ángulo siempre"],r1:"Confirmar el paso a la derecha — ver que el cruzado pasa por afuera",r2:"Combinar desde el ángulo derecho — se desorienta cuando el cruzado falla",r3:"Si dominamos desde el ángulo — más confianza — si no — cerrar distancia"},
en:{name:"Southpaw",desc:"The southpaw cross comes from an unexpected angle — disorients those who don't know it",problem:"The southpaw cross arrives exactly where you don't expect — from the right side",tell:"Right shoulder rises slightly before throwing the cross",planA:"Jab + step to the RIGHT of opponent + cross passes outside + combination from the angle + exit",planB:"Close distance + inside work — the southpaw cross loses power at close range",pts:["Step to the right ALWAYS — the southpaw cross passes outside","Combination from the right angle — they can't respond well from there","NEVER straight — the angle always"],r1:"Confirm the right step — see that the cross passes outside",r2:"Combine from the right angle — they get disoriented when the cross fails",r3:"If we dominate from the angle — more confidence — if not — close distance"}},
{color:"#1a6b3c",
es:{name:"Alto con Jab Largo",desc:"Controla la distancia con jab largo — previene la entrada — domina desde lejos",problem:"Si respetas su distancia dominan toda la pelea sin que puedas alcanzarlos",tell:"El peso se mueve hacia atrás antes de tirar el jab — listo para escapar",planA:"Esquivar el jab (cabeza afuera) + cerrar distancia en el mismo movimiento + combinación adentro donde la ventaja de altura desaparece + salida lateral",planB:"Propio jab para medir + falsa entrada + cerrar cuando reacciona al amago",pts:["No respetar su distancia — cerrar activamente — adentro desaparece la ventaja de altura","Esquivar el jab — cabeza afuera — nunca absorber recto","Salida lateral después de la combinación — no quedarse donde puede usar el jab"],r1:"Medir el jab — ver velocidad y timing — preparar el esquive",r2:"Esquivar + cerrar — si funciona — pierde su arma principal",r3:"Si cerramos bien — se frustra — más presión adentro"},
en:{name:"Tall Opponent with Long Jab",desc:"Controls distance with long jab — prevents entry — dominates from far out",problem:"If you respect their distance they dominate the whole fight without you reaching them",tell:"Weight moves back before throwing the jab — ready to escape",planA:"Slip the jab (head outside) + close distance in same motion + combination inside where height advantage disappears + lateral exit",planB:"Own jab to measure + false attack + close when they react to the feint",pts:["Don't respect their distance — close actively — inside the height advantage disappears","Slip the jab — head outside — never absorb straight","Lateral exit after the combination — don't stay where they can use the jab"],r1:"Measure the jab — see speed and timing — prepare the slip",r2:"Slip + close — if working — they lose their main weapon",r3:"If we've closed well — they're frustrated — more inside pressure"}},
{color:"#5a3a1a",
es:{name:"Buscador de Combinaciones",desc:"Lanza combinaciones largas de 4-8 golpes — intenta abrumar con volumen",problem:"Si no te mueves las combinaciones acumulan daño aunque no todas sean limpias",tell:"Respiración corta antes de la combinación — peso centra para estabilidad",planA:"Movimiento lateral constante + desviar primer golpe de la combinación + entrar DURANTE la combinación (después del 3-4 golpe están más débiles) + contragolpe + salida",planB:"Esperar el final de la combinación + contragolpe cuando están en el punto ciego + salida",pts:["Movimiento lateral constante — nunca quieto — necesitan base estable para combinar","Entrar cuando la combinación lleva 3-4 golpes — ese es su punto más débil","Salida lateral siempre — no quedarse donde pueden tirar la siguiente combinación"],r1:"Ver cuántos golpes tiene su combinación favorita — identificar el punto débil",r2:"Contragolpe en el punto débil de la combinación — los sorprende",r3:"Si acostumbrado a contrarrestar ahí — empiezan a dudar antes de combinar"},
en:{name:"Combination Puncher",desc:"Throws long combinations of 4-8 punches — tries to overwhelm with volume",problem:"If you don't move the combinations accumulate damage even if not all clean",tell:"Short breath before combination — weight centers for stability",planA:"Constant lateral movement + deflect first punch + enter DURING combination (after 3-4 punches they're weakest) + counter + exit",planB:"Wait for end of combination + counter when in blind spot + exit",pts:["Constant lateral movement — never still — they need stable base to combine","Enter when combination is 3-4 punches in — that's their weakest point","Lateral exit always — don't stay where they can throw the next combination"],r1:"See how many punches in their favorite combination — identify weak point",r2:"Counter at the weak point — it surprises them",r3:"If used to countering there — they start doubting before combining"}},
{color:"#2a4a6a",
es:{name:"Defensivo / Evasivo",desc:"Siempre en movimiento — difícil de pegar — espera tu error para atacar",problem:"Si lo persigues sin plan gastas energía sin pegarle y espera tu error",tell:"Siempre en las puntas de los pies — listo para moverse — ojos activos",planA:"Cortar el ring (moverse en ángulos no en línea recta) + presión con jab + forzar la esquina + combinación cuando no tiene salida + salida",planB:"Jab constante para marcar + seguir sin perseguir + combinación cuando se detiene para responder",pts:["Cortar el ring — ángulos — no perseguir en línea recta","Jab constante para obligarlo a parar — sin jab no hay presión","Combinación cuando para o llega a la esquina — ahí no puede escapar"],r1:"Aprender su movimiento — qué lado se mueve más — cortar ese lado",r2:"Forzar la esquina — una vez cortado — la pelea cambia completamente",r3:"Si cansado — la evasión baja — presión final"},
en:{name:"Defensive / Evasive Fighter",desc:"Always moving — hard to hit — waits for your mistake to attack",problem:"If you chase without a plan you waste energy without hitting them",tell:"Always on balls of feet — ready to move — active eyes",planA:"Cut the ring (move at angles not straight lines) + jab pressure + force the corner + combination when they have no exit + exit",planB:"Constant jab to mark + follow without chasing + combination when they stop to respond",pts:["Cut the ring — angles — don't chase in straight line","Constant jab to force them to stop — without jab there's no pressure","Combination when they stop or reach corner — there they can't escape"],r1:"Learn their movement — which way they move most — cut that side",r2:"Force the corner — once cut — the fight changes completely",r3:"If tired — evasion drops — final pressure"}}
];
const ld=(k,d)=>{try{const r=localStorage.getItem(k);return r?JSON.parse(r):d;}catch(e){return d;}};
const sv=(k,v)=>{try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}};
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2);
function age(d){if(!d)return"—";const b=new Date(d),t=new Date();let a=t.getFullYear()-b.getFullYear();if(t<new Date(t.getFullYear(),b.getMonth(),b.getDate()))a--;return a;}
function fD(d){if(!d)return"—";try{return new Date(d).toLocaleDateString(ST.lang==="es"?"es-ES":"en-US",{day:"2-digit",month:"short",year:"numeric"});}catch(e){return d;}}
function ini(n){return n.split(" ").slice(0,2).map(x=>x[0]||"").join("").toUpperCase();}
function esc(s){return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
function avC(n){return AVC[n.charCodeAt(0)%AVC.length];}
function t(){return T[ST.lang];}
function L(es,en){return ST.lang==="es"?es:en;}
function B(n,d,tm){return{n,d,t:tm};} // session block
function av(name,sz){const c=avC(name);const r=Math.round(sz/4);return`<div class="av" style="width:${sz}px;height:${sz}px;border-radius:${r}px;background:${c};font-size:${Math.round(sz*.35)}px">${esc(ini(name))}</div>`;}
function badge(ph,wk,sm){const c=PC[ph]||PC[1];const p=t().pn(ph),w=t().wn(wk);const pad=sm?"2px 8px":"4px 10px";const fs=sm?11:13;return`<div style="display:inline-flex;align-items:center;gap:4px;background:${c};border-radius:6px;padding:${pad}"><span style="font-size:${fs}px;color:#fff">${esc(p)}</span><span style="font-size:${sm?10:12}px;color:rgba(255,255,255,.7)">${esc(w)}</span></div>`;}
function sdot(st){const c=t().sc[st]||"#7a9ab5";return`<span style="display:inline-flex;align-items:center;gap:4px"><span style="width:6px;height:6px;border-radius:50%;background:${c};display:inline-block"></span><span style="font-size:10px;color:${c};font-family:Barlow;font-weight:600">${esc(st||"").toUpperCase()}</span></span>`;}
function sh(title,icon){return`<div class="sh"><span>${icon}</span><span class="st">${esc(title).toUpperCase()}</span><div class="sl"></div></div>`;}
function ec(msg){return`<div class="card" style="text-align:center;color:#4a6a8a;font-family:Barlow;font-size:13px">${esc(msg)}</div>`;}
function mwrap(content){return`<div class="modal-bg" onclick="closeMBG(event)"><div class="modal-box" onclick="event.stopPropagation()"><div style="display:flex;justify-content:flex-end;margin-bottom:12px"><button onclick="closeM()" class="btn btn-d" style="width:auto;padding:6px 14px;font-size:13px">✕ ${L("CERRAR","CLOSE")}</button></div>${content}</div></div>`;}
function inp(lb,k,tp,val,ext){return`<div style="margin-bottom:10px"><label class="lbl">${esc(lb).toUpperCase()}</label><input type="${tp}" class="inp" id="f-${k}" value="${esc(val||"")}" ${ext||""}></div>`;}
function sel(lb,k,opts,val){return`<div style="margin-bottom:10px"><label class="lbl">${esc(lb).toUpperCase()}</label><select class="inp" id="f-${k}">${opts.map(o=>`<option value="${esc(o)}"${o===val?" selected":""}>${esc(o)}</option>`).join("")}</select></div>`;}
function p1Session(week, dow, is90) {
const di = dow===0?6:dow-1;
if(di>=5) return null; // rest
const hm = week>=7;
const wk = WP[1][week]||WP[1][1];
const el = L(wk.es,wk.en), ri = L(wk.re,wk.rn), pct = wk.p;
const pc = PC[1];
if(di===0||di===2) { // Mon/Wed - Cuerda+Técnica
const isMon = di===0;
const tecTime = is90?(hm?"18 min":"20 min"):"10 min";
let blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"15 min":"10 min"),
B(L("Cuerda imaginaria","Shadow rope"), "15 min — "+ri+" — "+pct+"%", is90?"15 min":"12 min"),
B("Shadow Sagarra", L("Sistema completo — ","Full system — ")+ri+" — "+pct+"%", is90?"10 min":"8 min"),
B(L("Técnica dirigida","Directed technique"), (isMon?L("Construcción: ","Build: "):L("Aplicación: ","Apply: "))+el, tecTime),
B(L("Saco táctico","Tactical bag"), is90?L("3 asaltos × 3 min / 1 min = 11 min","3 rounds × 3 min / 1 min = 11 min"):L("3 asaltos × 2 min / 1 min = 8 min","3 rounds × 2 min / 1 min = 8 min"), is90?"11 min":"8 min"),
];
if(hm) blocks.push(B(L("Mascota","Pad work"), is90?L("2 asaltos × 3 min / 1 min = 7 min","2 rounds × 3 min / 1 min = 7 min"):L("2 asaltos × 2 min / 1 min = 5 min","2 rounds × 2 min / 1 min = 5 min"), is90?"7 min":"5 min"));
blocks.push(B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=6?"2":week<=9?"3":"4")+" Fase 1", is90?(hm?"9 min":"14 min"):"7 min"));
blocks.push(B(L("Estiramiento","Stretching"), L("Completo","Full"), "5 min"));
const title = isMon?L("Cuerda + Construcción","Rope + Build"):L("Cuerda + Aplicación","Rope + Apply");
return {title,blocks,el,ri,pct,pc,type:"lx"};
}
if(di===1||di===3) { // Tue/Thu - Carrera+Escuela
const isThu = di===3;
const hasSpar = hm&&isThu;
let blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"15 min":"10 min"),
B(L("Carrera continua","Continuous run"), is90?L("20 min suave conversacional","20 min easy conversational"):L("15 min suave conversacional","15 min easy conversational"), is90?"20 min":"15 min"),
B("Shadow Sagarra", L("Plan activo — ","Active plan — ")+ri+" — "+pct+"%", is90?"10 min":"7 min"),
B(L("Escuela de combate","Combat school"), L("Corrección del punto débil — ","Weak point — ")+el, is90?(hasSpar?"15 min":"20 min"):"10 min"),
B(L("Saco técnico","Technical bag"), is90?L("2 asaltos × 3 min / 1 min = 7 min","2 rounds × 3 min / 1 min = 7 min"):L("2 asaltos × 2 min / 1 min = 5 min","2 rounds × 2 min / 1 min = 5 min"), is90?"7 min":"5 min"),
];
if(hasSpar) blocks.push(B(L("Sparring condicionado","Conditioned sparring"), is90?L("2 asaltos × 3 min / 1 min = 7 min","2 rounds × 3 min / 1 min = 7 min"):L("2 asaltos × 2 min / 1 min = 5 min","2 rounds × 2 min / 1 min = 5 min"), is90?"7 min":"5 min"));
else blocks.push(B(L("Shadow recuperación","Recovery shadow"), L("Suave — manos arriba","Easy — hands up"), is90?"8 min":"8 min"));
blocks.push(B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=6?"2":week<=9?"3":"4")+" Fase 1", is90?(hasSpar?"11 min":"13 min"):"8 min"));
blocks.push(B(L("Estiramiento","Stretching"), L("Completo","Full"), "5 min"));
const title = isThu?L("Carrera + Sparring","Run + Sparring"):L("Carrera + Escuela","Run + Drills");
return {title,blocks,el,ri,pct,pc,type:"mj"};
}
let blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"15 min":"10 min"),
B(L("4 tramos × 50m","4 × 50m sprints"), is90?L("80-88% velocidad / trote de regreso","80-88% speed / jog back"):L("80% velocidad / trote de regreso","80% speed / jog back"), is90?"10 min":"8 min"),
B(L("Shadow libre evaluado","Free evaluated shadow"), L("Entrenador registra sin intervenir","Coach records without intervening"), is90?"15 min":"12 min"),
B(L("Saco evaluación","Evaluation bag"), is90?L("3 asaltos × 3 min / 1 min = 11 min","3 rounds × 3 min / 1 min = 11 min"):L("3 asaltos × 2 min / 1 min = 8 min","3 rounds × 2 min / 1 min = 8 min"), is90?"11 min":"8 min"),
];
if(hm) blocks.push(B(L("Mascota evaluada","Evaluated pad work"), is90?L("2 asaltos × 3 min / 1 min = 7 min","2 rounds × 3 min / 1 min = 7 min"):L("2 asaltos × 2 min / 1 min = 5 min","2 rounds × 2 min / 1 min = 5 min"), is90?"7 min":"5 min"));
blocks.push(B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=6?"2":week<=9?"3":"4")+" Fase 1", is90?(hm?"15 min":"25 min"):"10 min"));
blocks.push(B(L("Evaluación semanal","Weekly evaluation"), L("2 positivos + 1 a mejorar","2 positives + 1 to improve"), is90?(hm?"12 min":"9 min"):"7 min"));
blocks.push(B(L("Estiramiento","Stretching"), L("Completo","Full"), "5 min"));
return {title:L("Tramos + Evaluación","Sprints + Eval"),blocks,el,ri,pct,pc,type:"v"};
}
function p2Session(week, dow, is90) {
const di = dow===0?6:dow-1;
if(di>=5) return null;
const wk = WP[2][week]||WP[2][1];
const el = L(wk.es,wk.en), ri = L(wk.re,wk.rn), pct = wk.p;
const pc = PC[2];
const b1 = week<=3; // Bloque 1:lighter sparring (2 min rounds)
const sparStr = is90?(b1?L("5 asaltos × 2 min / 1 min = 14 min — solo rectos","5 rounds × 2 min / 1 min = 14 min — straights only"):L("5 asaltos × 3 min / 1 min = 19 min","5 rounds × 3 min / 1 min = 19 min")):(b1?L("4 asaltos × 2 min / 1 min = 11 min — solo rectos","4 rounds × 2 min / 1 min = 11 min — straights only"):L("4 asaltos × 3 min / 1 min = 15 min","4 rounds × 3 min / 1 min = 15 min"));
const sparT = is90?(b1?"14 min":"19 min"):(b1?"11 min":"15 min");
const mascStr = is90?L("5 asaltos × 3 min / 1.5 min = 21 min","5 rounds × 3 min / 1.5 min = 21 min"):L("4 asaltos × 3 min / 1.5 min = 17 min","4 rounds × 3 min / 1.5 min = 17 min");
const mascT = is90?"21 min":"17 min";
const sacoStr = is90?L("4 asaltos × 2 min / 1 min = 11 min","4 rounds × 2 min / 1 min = 11 min"):L("3 asaltos × 2 min / 1 min = 8 min","3 rounds × 2 min / 1 min = 8 min");
const sacoT = is90?"11 min":"8 min";
if(di===0||di===2) { // Mon/Wed:Cuerda + Tramos + Mascota + Saco (VERIFIED)
const blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"12 min":"10 min"),
B(L("Cuerda imaginaria","Shadow rope"), (is90?"20 min":"18 min")+L(" — rival "+ri+" — ráfaga "+(is90?"12":"8")+" rectos cada 2:30"," — "+ri+" — "+( is90?"12":"8")+" straights every 2:30"), is90?"20 min":"18 min"),
B(L("4 tramos × 50m","4 × 50m sprints"), L(pct+"% / trote de regreso",pct+"% / jog back"), "7 min"),
B("Shadow Sagarra", ri+" — "+L("plan activo","active plan")+" — "+pct+"%", is90?"10 min":"8 min"),
B(L("Mascota educativa","Educational pad work"), mascStr+" — 70%", mascT),
B(L("Saco técnico","Technical bag"), sacoStr, sacoT),
B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=7?"2":"3")+" Fase 2", is90?"9 min":"7 min"),
];
const title = di===0?L("Cuerda + Mascota + Saco","Rope + Pads + Bag"):L("Cuerda + Mascota + Saco (Var)","Rope + Pads + Bag (Var)");
return {title,blocks,el,ri,pct,pc,type:"lx"};
}
if(di===1||di===3) { // Tue/Thu:Carrera + Escuela + SPARRING (VERIFIED - BOTH DAYS)
const isThu = di===3;
const escTime = is90?(b1?"15 min":"12 min"):"10 min";
const recupTime = is90?(b1?"10 min":"8 min"):"8 min";
const blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"12 min":"10 min"),
B(L("Carrera continua","Continuous run"), is90?L("22 min conversacional","22 min conversational"):L("20 min conversacional","20 min conversational"), is90?"22 min":"20 min"),
B("Shadow Sagarra", ri+" — "+pct+"%", is90?"10 min":"8 min"),
B(L("Escuela de combate","Combat school"), L("Corrección individual — ","Individual correction — ")+el, escTime),
B(L("Sparring condicionado","Conditioned sparring"), sparStr, sparT),
B(L("Shadow recuperación","Recovery shadow"), L("Ritmo suave — manos ARRIBA","Easy rhythm — hands UP"), recupTime),
B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=7?"2":"3")+" Fase 2", is90?"7 min":"4 min"),
];
const title = isThu?L("Carrera + Sparring + Análisis","Run + Sparring + Analysis"):L("Carrera + Escuela + Sparring","Run + Drills + Sparring");
return {title,blocks,el,ri,pct,pc,type:"mj"};
}
const sacoVStr = is90?L("5 asaltos × 3 min / 1.5 min = 21 min — sistema completo","5 rounds × 3 min / 1.5 min = 21 min — full system"):L("4 asaltos × 3 min / 1.5 min = 17 min — sistema completo","4 rounds × 3 min / 1.5 min = 17 min — full system");
const blocks = [
B(L("Calentamiento dinámico","Dynamic warm-up"), L("Movilidad completa","Full mobility"), is90?"12 min":"10 min"),
B(L("6 tramos × 50m + 2 × 100m","6 × 50m + 2 × 100m sprints"), L((is90?"83":"80")+"% / trote de regreso",(is90?"83":"80")+"% / jog back"), "14 min"),
B(L("Shadow libre evaluado","Free evaluated shadow"), L("Entrenador evalúa sin intervenir","Coach evaluates without intervening"), is90?"18 min":"15 min"),
B(L("Saco táctico","Tactical bag"), sacoVStr, is90?"21 min":"17 min"),
B(L("Físico","Physical"), L("Ver protocolo Bloque ","See Block ")+(week<=3?"1":week<=7?"2":"3")+" Fase 2", is90?"10 min":"8 min"),
B(L("Evaluación individual","Individual evaluation"), L("2 positivos + 1 a mejorar","2 positives + 1 to improve"), is90?"15 min":"11 min"),
];
return {title:L("Tramos + Shadow + Evaluación","Sprints + Shadow + Eval"),blocks,el,ri,pct,pc,type:"v"};
}
function p3Session(week, dow, is90) {
const di = dow===0?6:dow-1;
if(di>=5) return null;
const wk = WP[3][week]||WP[3][1];
const el = L(wk.es,wk.en), ri = L(wk.re,wk.rn), pct = wk.p;
const pc = PC[3];
const mascStr = is90?L("5 asaltos × 3 min / 1 min = 19 min","5 rounds × 3 min / 1 min = 19 min"):L("4 asaltos × 3 min / 1 min = 15 min","4 rounds × 3 min / 1 min = 15 min");
const mascT = is90?"19 min":"15 min";
