function getSessData(phase, week, dow, group) {
const di = dow===0?6:dow-1;
if(di>=5) return {title:L("Descanso Completo","Full Rest"),blocks:[],el:"",ri:"",pct:0,pc:"#1e3050",type:"rest"};
const is90 = !(group&&(group.includes("C")||group.includes("Grupo C")||group.includes("Group C")||group.includes("B")||group.includes("Grupo B")||group.includes("Group B")));
let result;
if(phase===1) result = p1Session(week,dow,is90);
else if(phase===2) result = p2Session(week,dow,is90);
else if(phase===3) result = p3Session(week,dow,is90);
else if(phase===4) result = p4Session(week,dow,is90);
else result = null;
if(!result) return {title:L("Descanso Activo","Active Rest"),blocks:[],el:L("Mantenimiento","Maintenance"),ri:"",pct:70,pc:PC[5]||"#4a4a1a",type:"rest"};
result.dur = result.blocks.reduce((s,b)=>s+(parseInt(b.t)||0),0);
return result;
}
function sessCard(s,id,open){
const isR=s.type==="rest"||s.type==="fight";
const dur=s.dur||0;
let h=`<div class="card" style="padding:0;overflow:hidden;${open?`border-color:${s.pc}`:""}">`;
h+=`<div onclick="toggleSC('${id}')" style="padding:13px 14px;display:flex;justify-content:space-between;align-items:center;cursor:pointer">`;
h+=`<div style="flex:1"><div style="font-weight:800;font-size:17px;color:#fff">${esc(s.title)}</div>`;
if(s.el&&s.type!=="rest")h+=`<div style="font-size:11px;color:#D4A017;font-family:Barlow;font-weight:600;margin-top:2px">${esc(s.el)}</div>`;
h+=`</div><div style="display:flex;align-items:center;gap:8px">`;
h+=`<div style="background:${isR?"#1e3050":s.pc};border-radius:6px;padding:4px 10px;font-weight:700;font-size:13px;color:#fff">${isR?L("Descanso","Rest"):dur+" min"}</div>`;
h+=`<span id="arr-${id}" style="color:#D4A017;font-size:14px">${open?"▲":"▼"}</span></div></div>`;
h+=`<div id="bd-${id}" style="${open?"":"display:none"}">`;
if(!isR&&s.blocks.length>0){
h+=`<div style="padding:8px 14px;background:#0a1628;display:flex;gap:16px;flex-wrap:wrap">`;
h+=`<div><span style="font-size:10px;color:#7a9ab5;font-family:Barlow">${L("Rival:","Opponent:")} </span><span style="font-size:10px;color:#fff;font-family:Barlow;font-weight:600">${esc(s.ri||s.rival||"")}</span></div>`;
h+=`<div><span style="font-size:10px;color:#7a9ab5;font-family:Barlow">${L("Intensidad:","Intensity:")} </span><span style="font-size:10px;color:#D4A017;font-family:Barlow;font-weight:600">${s.pct||0}%</span></div></div>`;
s.blocks.forEach((b,i)=>{
h+=`<div style="display:flex;align-items:flex-start;gap:10px;padding:7px 14px;border-top:1px solid #0f1e35;background:${i%2===0?"#0a1420":"transparent"}">`;
h+=`<div style="width:44px;text-align:right;font-size:12px;color:#D4A017;font-weight:700;flex-shrink:0;padding-top:2px">${esc(b.t)}</div>`;
h+=`<div style="flex:1"><div style="font-weight:700;font-size:13px;color:#fff">${esc(b.n)}</div><div style="font-size:11px;color:#7a9ab5;font-family:Barlow;line-height:1.3">${esc(b.d)}</div></div></div>`;
});
h+=`<div style="padding:8px 14px;background:linear-gradient(135deg,#1a2744,#0f1e35);display:flex;justify-content:space-between"><span style="font-size:13px;color:#7a9ab5;font-weight:700">TOTAL</span><span style="font-size:15px;color:#D4A017;font-weight:800">${dur} min</span></div>`;
}
h+=`</div></div>`;
return h;
}
function toggleSC(id){const bd=document.getElementById("bd-"+id);const ar=document.getElementById("arr-"+id);if(!bd)return;const vis=bd.style.display!=="none";bd.style.display=vis?"none":"block";if(ar)ar.textContent=vis?"▼":"▲";}
function goTab(tab){
ST.tab=tab;
document.querySelectorAll(".page").forEach(p=>p.classList.remove("on"));
const pg=document.getElementById("pg-"+tab);
if(pg)pg.classList.add("on");
document.querySelectorAll(".nb").forEach(b=>{b.classList.remove("on");const bar=b.querySelector(".bar");if(bar)bar.remove();});
const nb=document.getElementById("nb-"+tab);
if(nb){nb.classList.add("on");if(!nb.querySelector(".bar")){const d=document.createElement("div");d.className="bar";nb.appendChild(d);}}
renderTab(tab);
}
function renderTab(tab){
const el=document.getElementById("pg-"+tab);
if(!el)return;
el.classList.remove("fi");void el.offsetWidth;el.classList.add("fi");
if(tab==="home")el.innerHTML=renderHome();
else if(tab==="athletes")el.innerHTML=renderAthletes();
else if(tab==="training")el.innerHTML=renderTraining();
else if(tab==="fights")el.innerHTML=renderFights();
else if(tab==="tactics")el.innerHTML=renderTactics();
else if(tab==="notes")el.innerHTML=renderNotes();
else if(tab==="nutrition")el.innerHTML=renderNutrition();
else if(tab==="store")el.innerHTML=renderStore();
updateHdr();
}
function reRender(){renderTab(ST.tab);}
function updateHdr(){
const d=document.getElementById("hdr-date");
const u=document.getElementById("hdr-user");
const lb=document.getElementById("lang-btn");
if(d)d.textContent=new Date().toLocaleDateString(ST.lang==="es"?"es-ES":"en-US",{weekday:"short",day:"2-digit",month:"short"}).toUpperCase();
if(u)u.textContent=ST.isCoach?L("COACH OSVIMER","COACH OSVIMER"):(ST.isParent&&ST.parentUser?("PADRE — "+ST.parentUser.name.split(" ")[0].toUpperCase()):(ST.proUser?"PRO: "+(ST.proUser.name.split(" ")[0].toUpperCase()):(ST.user?ST.user.name.split(" ")[0].toUpperCase():"")))
if(lb)lb.textContent=ST.lang==="es"?"EN":"ES";
const icons=["🏠","🥊","📋","🏆","🎯","🥗","🛒","💬"];
const nav=document.getElementById("nav");
if(nav){
  if(ST.isParent){
    nav.innerHTML=`<button class="nb on" id="nb-home" onclick="goTab('home')"><span class="ic">🏠</span><span>${L("INICIO","HOME")}</span><div class="bar"></div></button>`;
  } else {
    nav.innerHTML=["home","athletes","training","fights","tactics","nutrition","store","notes"].map((id,i)=>`<button class="nb${ST.tab===id?" on":""}" id="nb-${id}" onclick="goTab('${id}')"><span class="ic">${icons[i]}</span><span>${t().nav[i]}</span>${ST.tab===id?'<div class="bar"></div>':""}</button>`).join("");
  }
}
}
function toggleLang(){const nl=ST.lang==="es"?"en":"es";ST.lang=nl;sv("cba_lang",nl);updateHdr();reRender();}

function renderProWeeklyPlan() {
  if (!ST.proUser || ST.proUser.isCoachPro) return "<div class='card'>Acceso solo para atletas PRO</div>";
  const fase = ST.proUser.proPhase || 1;
  const semana = ST.proUser.proWeek || 1;
  let progreso;
  try { progreso = JSON.parse(localStorage.getItem("pro_progress_" + ST.proUser.id)) || { completados: [] }; }
  catch(e) { progreso = { completados: [] }; }
  const phase = ProPhases.find(p=>p.id===fase)||ProPhases[0];
  let html = `<div class="card" style="background:#0a1628;margin-bottom:16px;">
    <div style="font-size:18px;font-weight:900;color:#D4A017;">📅 SEMANA ${semana} · FASE ${fase} — ${esc(phase.name)}</div>
    <div style="font-size:12px;color:#fff;font-family:Barlow;margin-top:4px;">🎯 ${esc(phase.focus)}</div>
    <div style="display:flex;gap:8px;margin-top:8px;flex-wrap:wrap;">
      <span style="background:#1e3050;padding:4px 12px;border-radius:20px;font-size:11px;">🇨🇺 Técnica Sagarra</span>
      <span style="background:#1e3050;padding:4px 12px;border-radius:20px;font-size:11px;">🇺🇸 Potencia/Sparring</span>
      <span style="background:#1e3050;padding:4px 12px;border-radius:20px;font-size:11px;">🇲🇽 Cuerpo/Presión</span>
    </div>
    <div style="font-size:11px;color:#D4A017;margin-top:6px;">✅ 4 días: LUN · MAR · JUE · VIE</div>
  </div>`;
  const days = ["mon","tue","thu","fri"];
  const dayNames = {mon:"🗓 LUN",tue:"🗓 MAR",thu:"🗓 JUE",fri:"🗓 VIE"};
  days.forEach(d=>{
    const session = phase.sessions&&phase.sessions[d];
    const completado = progreso.completados.includes(d);
    if(!session)return;
    html += `<div class="card" style="margin-bottom:12px;border-left:4px solid ${completado?"#1a8f4c":phase.color};">
      <div style="font-weight:800;font-size:17px;color:#fff;">${dayNames[d]} · ${esc(session.title)}</div>
      <div style="font-size:11px;color:#7a9ab5;font-family:Barlow;">~${session.dur||90} min · 🇨🇺🇺🇸🇲🇽</div>
      <div style="background:#0a1628;border-radius:8px;margin-top:8px;">`;
    session.blocks.forEach((b,i)=>{
      html+=`<div style="display:flex;gap:10px;padding:7px 10px;border-top:${i>0?"1px solid #0f1e35":"none"};">
        <div style="width:46px;text-align:right;font-size:11px;color:#D4A017;font-weight:700;flex-shrink:0;">${esc(b.t)}</div>
        <div><div style="font-weight:700;font-size:13px;color:#fff;">${esc(b.n)}</div>
        <div style="font-size:11px;color:#7a9ab5;font-family:Barlow;">${esc(b.d||"")}</div></div></div>`;
    });
    html+=`</div>
      <div style="display:flex;justify-content:space-between;padding-top:8px;margin-top:4px;border-top:1px solid #1e3050;">
       
