<title>Cuban Boxing App</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800;900&family=Barlow:wght@400;600&display=swap" rel="stylesheet">
<style>*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}body{background:#070d1a;color:#fff;font-family:'Barlow Condensed','Impact',sans-serif;min-height:100vh;overflow-x:hidden}#root{max-width:480px;margin:0 auto;position:relative}input,select,textarea{font-family:'Barlow',sans-serif;font-size:14px}button{cursor:pointer;font-family:'Barlow Condensed',sans-serif;transition:all .12s}button:active{transform:scale(.96);opacity:.82}.page{display:none;padding:14px 14px 90px;animation:fi .25s ease}.page.on{display:block}@keyframes fi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}#hdr{background:linear-gradient(135deg,#0a1628,#0f1e35);border-bottom:2px solid #D4A017;padding:11px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}#nav{position:fixed;bottom:0;left:0;right:0;background:#0a1628;border-top:2px solid #D4A017;display:flex;z-index:50;max-width:480px;margin:0 auto}.nb{flex:1;background:none;border:none;color:#4a6a8a;padding:10px 4px 6px;display:flex;flex-direction:column;align-items:center;gap:2px;font-size:9px;font-weight:700;letter-spacing:1px}.nb.on{color:#D4A017}.nb .ic{font-size:20px;line-height:1}.nb .bar{width:24px;height:2px;background:#D4A017;border-radius:1px;margin-top:2px}.card{background:#0f1e35;border-radius:12px;padding:14px;margin-bottom:10px;border:1px solid #1e3050}.card-g{border-color:#D4A017}.btn{width:100%;border:none;border-radius:10px;padding:13px;font-weight:800;font-size:15px;letter-spacing:1px;cursor:pointer}.btn-g{background:#D4A017;color:#070d1a}.btn-d{background:#1e3050;color:#D4A017}.btn-gr{background:#1a6b3c;color:#fff}.btn-r{background:#8b1a1a;color:#fff}.inp{width:100%;background:#0f1e35;border:1px solid #1e3050;border-radius:8px;padding:10px 12px;color:#fff;font-size:14px;outline:none}.inp:focus{border-color:#D4A017}.lbl{font-size:11px;color:#7a9ab5;display:block;margin-bottom:4px;letter-spacing:.5px;font-family:'Barlow'}.av{border-radius:25%;display:flex;align-items:center;justify-content:center;font-weight:900;color:#fff;flex-shrink:0}.sh{display:flex;align-items:center;gap:8px;margin-bottom:8px}.sh span:first-child{font-size:14px}.sh .st{font-size:13px;color:#D4A017;font-weight:800;letter-spacing:2px}.sh .sl{flex:1;height:1px;background:#1e3050}.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:100;display:flex;align-items:flex-end}.modal-box{background:#0a1628;border-radius:20px 20px 0 0;padding:20px 16px;width:100%;max-height:92vh;overflow-y:auto;border:1px solid #1e3050;animation:fi .2s ease}.prog-wrap{background:#1e3050;border-radius:4px;height:6px;overflow:hidden}.prog-fill{height:100%;background:#D4A017;border-radius:4px}.frow{display:flex;gap:8px;margin-bottom:10px}.fcol{flex:1}.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}.filter-row{display:flex;gap:6px;margin-bottom:14px;overflow-x:auto;padding-bottom:4px}.fb{border:none;border-radius:20px;padding:5px 12px;font-size:11px;font-weight:700;white-space:nowrap;cursor:pointer}.pin-box{display:flex;justify-content:center;gap:8px;margin:16px 0}.pin-dot{width:16px;height:16px;border-radius:50%;background:#1e3050;border:2px solid #D4A017;transition:background .15s}.pin-dot.filled{background:#D4A017}.pin-num-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;max-width:260px;margin:0 auto}.pin-btn{background:#0f1e35;border:1px solid #1e3050;border-radius:12px;padding:18px;font-size:24px;font-weight:800;color:#fff;cursor:pointer}.pin-btn:active{background:#D4A017;color:#070d1a}.style-card{border-left:4px solid;margin-bottom:8px}.style-hdr{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;cursor:pointer}.style-body{padding:0 14px 12px;display:none}.style-body.on{display:block}.note-area{width:100%;background:#0a1628;border:1px solid #1e3050;border-radius:8px;padding:10px;color:#fff;resize:none;font-family:'Barlow',sans-serif;font-size:13px;margin-top:6px}.msg-bubble{border-radius:10px;padding:10px 12px;margin-bottom:8px;max-width:90%}.msg-ath{background:#1e3050;align-self:flex-start;border-bottom-left-radius:2px}.msg-coach{background:#1a6b3c;align-self:flex-end;border-bottom-right-radius:2px;margin-left:auto}::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:#D4A017;border-radius:2px}</style>
<script>(function(){
var manifest={name:"Cuban Boxing App",short_name:"CBA Boxing",description:"Metodologia Sagarra — Coach Osvimer Rodriguez",start_url:"./",scope:"./",display:"standalone",background_color:"#070d1a",theme_color:"#D4A017",orientation:"portrait-primary",icons:[{src:"data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='90' fill='%230d1f3c'/%3E%3Ctext x='256' y='340' font-family='Arial Black' font-size='200' font-weight='900' fill='%23D4A017' text-anchor='middle'%3ECBA%3C/text%3E%3C/svg%3E",sizes:"512x512",type:"image/svg+xml",purpose:"any maskable"}]};
var blob=new Blob([JSON.stringify(manifest)],{type:"application/manifest+json"});
var l=document.createElement("link");l.rel="manifest";l.href=URL.createObjectURL(blob);document.head.appendChild(l);
var ai=document.createElement("link");ai.rel="apple-touch-icon";ai.href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='90' fill='%230d1f3c'/%3E%3Ctext x='256' y='340' font-family='Arial Black' font-size='200' font-weight='900' fill='%23D4A017' text-anchor='middle'%3ECBA%3C/text%3E%3C/svg%3E";document.head.appendChild(ai);
})();</script>
</head>
<body>
<div id="root">
<div id="app"></div>
<div id="main-shell" style="display:none">
<div id="hdr">
<div style="display:flex;align-items:center;gap:10px">
<div id="hdr-logo" style="width:44px;height:44px;flex-shrink:0"></div>
<div><div style="font-weight:900;font-size:15px;letter-spacing:1.5px;color:#fff;line-height:1.1">CUBAN BOXING APP</div><div style="font-size:9px;color:#D4A017;letter-spacing:1px;font-family:Barlow;font-weight:600">OSVIMER COACH</div></div>
</div>
<div style="display:flex;align-items:center;gap:6px">
<div style="text-align:right"><div id="hdr-date" style="font-size:10px;color:#7a9ab5;font-family:Barlow"></div><div id="hdr-user" style="font-size:9px;color:#D4A017;font-family:Barlow"></div></div>
<button onclick="toggleLang()" id="lang-btn" style="background:linear-gradient(135deg,#D4A017,#f0c040);border:none;color:#070d1a;border-radius:8px;padding:7px 8px;font-weight:900;font-size:12px;letter-spacing:1px">EN</button>
<button onclick="showSwitchModal()" style="background:#8b1a1a;border:2px solid #e74c3c;color:#fff;border-radius:8px;padding:7px 10px;font-weight:900;font-size:12px">SALIR</button>
</div>
</div>
<div id="pages">
<div id="pg-home" class="page on"></div>
<div id="pg-athletes" class="page"></div>
<div id="pg-training" class="page"></div>
<div id="pg-fights" class="page"></div>
<div id="pg-tactics" class="page"></div>
<div id="pg-nutrition" class="page"></div>
<div id="pg-store" class="page"></div>
<div id="pg-notes" class="page"></div><div id="pg-pricing" class="page"></div>
</div>
<nav id="nav"></nav>
</div>
<div id="modal-wrap"></div>
</div>
<script>window.onerror = function(msg, src, line, col, err) {
document.body.innerHTML = '<div style="background:#070d1a;color:#fff;padding:20px;font-family:sans-serif;min-height:100vh">' +
'<div style="color:#D4A017;font-size:20px;font-weight:bold;margin-bottom:16px">⚠ ERROR</div>' +
'<div style="color:#ff6b6b;font-size:14px;margin-bottom:8px">' + msg + '</div>' +
'<div style="color:#7a9ab5;font-size:12px">Line: ' + line + '</div>' +
'<div style="color:#7a9ab5;font-size:12px;margin-top:8px">File: ' + src + '</div>' +
'<div style="color:#7a9ab5;font-size:11px;margin-top:16px">Send this screenshot to Coach</div>' +
'</div>';
return true;
};
